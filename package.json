{
  "name": "bank-atlas-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic, read-only tooling for the no-app personal finance snapshot workflow. The AI agent extracts visible bank data into input/banks/*.json; these tools normalize it and build output/ snapshot files, run the safety + quality checklist, and scaffold new banks.",
  "type": "module",
  "bin": {
    "atlas": "tools/cli.js"
  },
  "scripts": {
    "build": "node --disable-warning=ExperimentalWarning tools/cli.js build",
    "validate": "node tools/cli.js validate",
    "audit": "node tools/cli.js audit",
    "review": "node tools/cli.js review",
    "serve": "node tools/cli.js serve",
    "new-bank": "node tools/cli.js new-bank",
    "ingest": "node tools/cli.js ingest",
    "db": "node --disable-warning=ExperimentalWarning tools/cli.js db",
    "db:list": "node --disable-warning=ExperimentalWarning tools/cli.js db list",
    "db:read": "node --disable-warning=ExperimentalWarning tools/cli.js db read",
    "trends": "node --disable-warning=ExperimentalWarning tools/cli.js trends",
    "demo-banks": "node tools/cli.js demo-banks",
    "seed-demo-banks": "node --disable-warning=ExperimentalWarning tools/cli.js seed-demo-banks",
    "banks:list": "node --disable-warning=ExperimentalWarning tools/cli.js banks list",
    "test": "node --test \"tools/test/*.test.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "license": "Apache-2.0"
}
