vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# --- bank-atlas privacy ---
# Dedicated automation browser profiles (cookies, sessions) — never commit.
.browser-profiles/

config/banks/*.md
!config/banks/demo-cards.md
!config/banks/demo-loans.md
!config/banks/demo-savings.md

# Real per-bank extraction data. Keep only the example checked in.
input/banks/*.json
!input/banks/example-bank.json
!input/banks/demo-savings.json
!input/banks/demo-cards.json
!input/banks/demo-loans.json

# User-editable item metadata (names, limits, due days). Keep example only.
config/items/*.json
!config/items/example-bank.json
!config/items/demo-savings.json
!config/items/demo-cards.json
!config/items/demo-loans.json

# Timestamped snapshot history may contain real financial data.
output/history/

# Local statements you drop in for offline ingestion (keep the README only).
statements/*
!statements/README.md

# SQLite history database contains real financial data.
*.db
*.db-journal
*.db-wal
*.db-shm
.playwright-mcp
output/financial-snapshot.md
output/financial-snapshot.json
output/credit_cards.csv
output/accounts.csv
output/loans.csv
output/transactions.csv
